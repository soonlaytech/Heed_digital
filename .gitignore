# ─── Environment Variables (NEVER commit secrets) ─────────────────────────────
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example
*.local
*.pem

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Cache / Temp ─────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.vite/
.turbo/
.eslintcache
*.tsbuildinfo

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Package Manager Locks (keep only the one you use) ───────────────────────
# yarn.lock        # uncomment if using yarn
# pnpm-lock.yaml   # uncomment if using pnpm

# ─── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
.history/
.vscode-test/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

