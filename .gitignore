.replit
replit.nix
# ─── Misc Temporary Files ────────────────────────────────────────────────────
tmp/
temp/
*.tmp

# ─── Runtime Files ───────────────────────────────────────────────────────────
*.pid
*.seed
*.pid.lock

# ─── Local Databases ──────────────────────────────────────────────────────────
*.sqlite
*.sqlite3

# ─── Firebase ────────────────────────────────────────────────────────────────
.firebase/

